{
  // See https://go.microsoft.com/fwlink/?LinkId=733558
  // for the documentation about the tasks.json format
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "dependsOrder": "sequence",
      "dependsOn": [
        // "buildGodot",
        "buildSnoreCore",
        "buildScaffolder",
        "buildSurfacer",
        "buildDocs"
      ],
    },
    {
      "label": "buildRelease",
      "dependsOrder": "sequence",
      "dependsOn": [
        "buildGodotRelease",
        "buildSnoreCoreRelease",
        "buildScaffolderRelease",
        "buildSurfacerRelease",
        "buildDocs"
      ],
    },
    {
      "label": "buildAll",
      "dependsOrder": "sequence",
      "dependsOn": [
        "buildGodot",
        "buildSnoreCore",
        "buildScaffolder",
        "buildSurfacer",
        "buildDocs"
      ],
    },
    {
      "label": "buildSnoreCore",
      "group": "build",
      "type": "shell",
      "command": "scons",
      "args": [
        // Include and run SnoreCore tests
        "tests=yes",
        // Disable SnoreCore breakpoints when running in CI.
        // "ci=yes",
        // Enable dev_build for debugging with breakpoints.
        "dev_build=yes",
        "dev_mode=yes",
        "debug_symbols=yes",
        // "dev_mode=yes",
        // TODO: Consider toggling.
        "optimize=debug",
        // TODO: Consider toggling.
        // "tests=yes",
        // TODO: Consider toggling.
        // "target=editor",
        "target=template_debug",
        "platform=windows",
        "custom_api_file=${workspaceFolder}/extension_api.json"
      ],
      "problemMatcher": "$msCompile",
      "options": {
        "cwd": "${workspaceFolder}/snore_core"
      }
    },
    {
      "label": "buildSnoreCoreRelease",
      "group": "build",
      "type": "shell",
      "command": "scons",
