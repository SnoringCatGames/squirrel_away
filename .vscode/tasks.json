{
  // See https://go.microsoft.com/fwlink/?LinkId=733558
  // for the documentation about the tasks.json format
  "version": "2.0.0",
  "tasks": [
    {
      "label": "buildDev",
      "dependsOrder": "sequence",
      "dependsOn": [
        // "buildGodot",
        "buildExtensionDev",
        "buildDocs"
      ],
    },
    {
      "label": "buildAssetLibRelease",
      "dependsOrder": "sequence",
      "dependsOn": [
        // For now, we only publish template_debug versions of the extension.
        "buildDebug"
      ],
      "group": "build",
      "type": "shell",
      "command": "scons",
      "args": [
        // Skip the normal build process, and just zip the current build.
        "sc_zip=yes",
      ],
      "problemMatcher": "$msCompile",
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "buildDebug",
      "dependsOrder": "sequence",
      "dependsOn": [
        // "buildGodot",
        "buildExtensionDebug",
        "buildDocs"
      ],
    },
    {
      "label": "buildRelease",
      "dependsOrder": "sequence",
      "dependsOn": [
        // "buildGodotRelease",
        "buildExtensionRelease",
        "buildDocs"
      ],
    },
    {
      "label": "buildAll",
      "dependsOrder": "sequence",
      "dependsOn": [
        "buildGodot",
        "buildExtensionDev",
        "buildDocs"
      ],
    },
    {
      // Use this for internal development on the extension.
      "label": "buildExtensionDev",
      "group": "build",
      "type": "shell",
      "command": "scons",
      "args": [
        // Include SnoreCore debug logic used for internal development (defines SC_DEV_ENABLED).
        "sc_dev=yes",
        // Include and run SnoreCore tests (defines SC_TESTS_ENABLED).
        "sc_tests=yes",
        // Disable SnoreCore breakpoints when running in CI (defines SC_CI_ENABLED).
        // "sc_ci=yes",
        // Enable dev_build for debugging with breakpoints.
        "dev_build=yes",
        "dev_mode=yes",
        "debug_symbols=yes",
        // "dev_mode=yes",
        // TODO: Consider toggling.
        "optimize=debug",
        // TODO: Consider toggling.
        // "tests=yes",
        // TODO: Consider toggling.
        // "target=editor",
        "target=template_debug",
        "platform=windows",
        "custom_api_file=${workspaceFolder}/extension_api.json"
      ],
      "problemMatcher": "$msCompile",
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      // Use this for publishing the extension with the debug export template.
      "label": "buildExtensionDebug",
      "group": "build",
      "type": "shell",
      "command": "scons",
      "args": [
        // Exclude SnoreCore debug logic used for internal development (defines SC_DEV_ENABLED).
        // "sc_dev=yes",
        // Include and run SnoreCore tests (defines SC_TESTS_ENABLED).
        "sc_tests=yes",
        // Disable SnoreCore breakpoints when running in CI (defines SC_CI_ENABLED).
        // "sc_ci=yes",
        // Enable dev_build for debugging with breakpoints.
        "dev_build=yes",
        "dev_mode=yes",
        "debug_symbols=yes",
        // "dev_mode=yes",
        // TODO: Consider toggling.
        "optimize=debug",
        // TODO: Consider toggling.
        // "tests=yes",
        // TODO: Consider toggling.
        // "target=editor",
        "target=template_debug",
        "platform=windows",
        "custom_api_file=${workspaceFolder}/extension_api.json"
      ],
      "problemMatcher": "$msCompile",
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      // Use this for publishing the extension with the release export template.
      "label": "buildExtensionRelease",
      "group": "build",
      "type": "shell",
      "command": "scons",
      "args": [
        // Exclude SnoreCore debug logic used for internal development (defines SC_DEV_ENABLED).
        // "sc_dev=yes",
        // Exclude SnoreCore tests.
        // "sc_tests=yes",
        // Disable SnoreCore breakpoints when running in CI.
        // "sc_ci=yes",
        // Enable dev_build for debugging with breakpoints.
        // "dev_build=yes",
        // "dev_mode=yes",
        // "debug_symbols=yes",
        // "dev_mode=yes",
        // TODO: Consider toggling.
        // "optimize=debug",
        // TODO: Consider toggling.
        // "tests=yes",
        // TODO: Consider toggling.
        // "target=editor",
        "target=template_release",
        "platform=windows",
        "custom_api_file=${workspaceFolder}/extension_api.json"
      ],
      "problemMatcher": "$msCompile",
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      // Create doc XML files for symbols in the extension.
      // - These files can then be hand-edited to add descriptions.
      // - The SCons build will then add the edited documentation to the GDExtension.
      "label": "buildDocs",
      "group": "build",
      "type": "shell",
      "command": "${workspaceFolder}/godot/bin/godot.windows.editor.dev.x86_64.exe",
      // "command": "C:/Program Files/Godot/Godot_v4.4.1-stable_win64.exe",
      "args": [
        // Enable dev_build for debugging with breakpoints.
        "--doctool",
        "../",
        "--gdextension-docs",
      ],
      "problemMatcher": "$msCompile",
      "options": {
        "cwd": "${workspaceFolder}/demo"
      }
    },
    {
      "label": "buildGodot",
      "group": "build",
      "type": "shell",
      "command": "scons",
      "args": [
        // exclude SnoreCore debug logic used for internal development (defines SC_DEV_ENABLED).
        // "sc_dev=yes",
        // Include and run SnoreCore tests.
        // "sc_tests=yes",
        // Disable SnoreCore breakpoints when running in CI.
        // "sc_ci=yes",
        // Enable dev_build for debugging with breakpoints.
        "dev_build=yes",
        "dev_mode=yes",
        // TODO: Consider toggling.
        "debug_symbols=yes",
        // TODO: Consider toggling.
        "optimize=debug",
        // TODO: Consider toggling.
        "target=editor",
        // "target=template_debug",
        "platform=windows"
      ],
      "problemMatcher": "$msCompile",
      "options": {
        "cwd": "${workspaceFolder}/godot"
      }
    },
    {
      "label": "buildGodotRelease",
      "group": "build",
      "type": "shell",
      "command": "scons",
      "args": [
        // Enable dev_build for debugging with breakpoints.
        // "dev_build=yes",
        // "dev_mode=yes",
        // TODO: Consider toggling.
        // "debug_symbols=yes",
        // TODO: Consider toggling.
        "optimize=debug",
        // TODO: Consider toggling.
        "target=editor",
        // "target=template_debug",
        "platform=windows"
      ],
      "problemMatcher": "$msCompile",
      "options": {
        "cwd": "${workspaceFolder}/godot"
      }
    }
  ]
}