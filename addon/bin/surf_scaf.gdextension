[configuration]

entry_symbol = "surf_scaf_extension_init"
compatibility_minimum = "4.4"
reloadable = true

[libraries]

macos.debug = "res://addons/surf_scaf/bin/macos/macos.framework/SurfScaf.macos.template_debug"
macos.release = "res://addons/surf_scaf/bin/macos/macos.framework/SurfScaf.macos.template_release"
ios.debug = "res://addons/surf_scaf/bin/ios/ios.framework/SurfScaf.ios.template_debug"
ios.release = "res://addons/surf_scaf/bin/ios/ios.framework/SurfScaf.ios.template_release"
windows.debug.x86_32 = "res://addons/surf_scaf/bin/windows/SurfScaf.windows.template_debug.x86_32.dll"
windows.release.x86_32 = "res://addons/surf_scaf/bin/windows/SurfScaf.windows.template_release.x86_32.dll"
windows.debug.x86_64 = "res://addons/surf_scaf/bin/windows/SurfScaf.windows.template_debug.x86_64.dll"
windows.release.x86_64 = "res://addons/surf_scaf/bin/windows/SurfScaf.windows.template_release.x86_64.dll"
linux.debug.x86_64 = "res://addons/surf_scaf/bin/linux/SurfScaf.linux.template_debug.x86_64.so"
linux.release.x86_64 = "res://addons/surf_scaf/bin/linux/SurfScaf.linux.template_release.x86_64.so"
linux.debug.arm64 = "res://addons/surf_scaf/bin/linux/SurfScaf.linux.template_debug.arm64.so"
linux.release.arm64 = "res://addons/surf_scaf/bin/linux/SurfScaf.linux.template_release.arm64.so"
linux.debug.rv64 = "res://addons/surf_scaf/bin/linux/SurfScaf.linux.template_debug.rv64.so"
linux.release.rv64 = "res://addons/surf_scaf/bin/linux/SurfScaf.linux.template_release.rv64.so"
android.debug.x86_64 = "res://addons/surf_scaf/bin/android/SurfScaf.android.template_debug.x86_64.so"
android.release.x86_64 = "res://addons/surf_scaf/bin/android/SurfScaf.android.template_release.x86_64.so"
android.debug.arm64 = "res://addons/surf_scaf/bin/android/SurfScaf.android.template_debug.arm64.so"
android.release.arm64 = "res://addons/surf_scaf/bin/android/SurfScaf.android.template_release.arm64.so"

; [icons] block intentionally omitted — no editor icons are designed yet.
; When icons are added, declare per-class entries like:
;     ClassName = "res://addons/surf_scaf/icons/ClassName.svg"
